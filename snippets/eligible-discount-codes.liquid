{% if settings.show_eligible_discount_codes and cart.item_count > 0 %}
  {% capture discount_codes %}
    {% for discount_index in (1..5) %}
      {% liquid
        assign code_key = 'eligible_discount_code_' | append: discount_index
        assign minimum_key = 'eligible_discount_minimum_' | append: discount_index
        assign description_key = 'eligible_discount_description_' | append: discount_index
        assign discount_code = settings[code_key] | strip
        assign discount_minimum = settings[minimum_key] | default: 0 | times: 100 | round
        assign discount_description = settings[description_key] | strip
        assign amount_left = discount_minimum | minus: cart.total_price
        assign is_active = false

        if discount_minimum > 0 and cart.total_price >= discount_minimum
          assign is_active = true
        endif
      %}

      {% if discount_code != blank and discount_minimum > 0 %}
        <li class="eligible-discounts__item{% if is_active %} is-active{% else %} is-locked{% endif %}">
          {% if is_active %}
            <button
              class="eligible-discounts__code"
              type="button"
              data-discount-code="{{ discount_code | escape }}"
              aria-label="Copy discount code {{ discount_code | escape }}"
            >
              {{ discount_code | escape }}
            </button>
          {% else %}
            <span
              class="eligible-discounts__code eligible-discounts__code--locked"
              aria-label="Discount code {{ discount_code | escape }} unlocks at {{ discount_minimum | money }}"
            >
              {{ discount_code | escape }}
            </span>
          {% endif %}

          <span class="eligible-discounts__meta">
            <span class="eligible-discounts__description">
              {% if discount_description != blank %}
                {{ discount_description | escape }}
              {% else %}
                Unlocks at {{ discount_minimum | money }}
              {% endif %}
            </span>
            <span class="eligible-discounts__status">
              {% if is_active %}
                Active now. Click to copy.
              {% else %}
                Add {{ amount_left | money }} more to activate.
              {% endif %}
            </span>
          </span>
        </li>
      {% endif %}
    {% endfor %}
  {% endcapture %}
  {% liquid
    assign discount_codes = discount_codes | strip
  %}

  {% if discount_codes != blank %}
    <div class="eligible-discounts" aria-live="polite">
      <p class="eligible-discounts__eyebrow">Coupon codes</p>
      <p class="eligible-discounts__title">Available offers for your cart</p>
      <ul class="eligible-discounts__list list-unstyled" role="list">
        {{ discount_codes }}
      </ul>
      <p class="eligible-discounts__hint">Active codes can be copied and used at checkout.</p>
    </div>
  {% endif %}
{% endif %}
