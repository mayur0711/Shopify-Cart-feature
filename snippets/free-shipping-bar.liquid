{% assign free_shipping_threshold = 5000 %}
{% assign cart_total = cart.total_price %}
{% assign amount_left = free_shipping_threshold | minus: cart_total %}

<div
  class="free-shipping-bar"
  data-free-shipping-threshold="{{ free_shipping_threshold }}"
>
  <p class="free-shipping-message">
    {% if amount_left > 0 %}
      Spend {{ amount_left | money }} more to get FREE shipping!
    {% else %}
      Congratulations! You unlocked FREE shipping.
    {% endif %}
  </p>

  <div class="free-shipping-track">
    <div
      class="free-shipping-progress"
      style="width: {{ cart_total | times: 100 | divided_by: free_shipping_threshold | at_most: 100 }}%;"
    ></div>
  </div>
</div>