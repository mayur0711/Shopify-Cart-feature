{% liquid
  assign free_shipping_target = settings.free_shipping_threshold | default: 100
  assign free_shipping_threshold = free_shipping_target | times: 100 | round
  assign cart_total = cart.total_price
  assign amount_left = free_shipping_threshold | minus: cart_total
  assign progress = 0
  assign is_complete = false

  if free_shipping_threshold > 0
    assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold | at_most: 100
  endif

  if amount_left <= 0
    assign is_complete = true
  endif
%}

{% if cart.item_count > 0 and free_shipping_threshold > 0 %}
  <div
    class="free-shipping-bar{% if is_complete %} is-complete{% endif %}"
    data-free-shipping-threshold="{{ free_shipping_threshold }}"
    data-free-shipping-currency="{{ cart.currency.iso_code }}"
    style="--free-shipping-progress: {{ progress }}%;"
  >
    <div class="free-shipping-icon" aria-hidden="true">
      <span class="svg-wrapper free-shipping-icon__truck">
        {{- 'icon-truck.svg' | inline_asset_content -}}
      </span>
      <span class="svg-wrapper free-shipping-icon__check">
        {{- 'icon-checkmark.svg' | inline_asset_content -}}
      </span>
    </div>

    <div class="free-shipping-content">
      <p class="free-shipping-message" aria-live="polite">
        {% if amount_left > 0 %}
          <span class="free-shipping-emphasis">You're {{ amount_left | money }} away</span> from free shipping
        {% else %}
          <span class="free-shipping-emphasis">Free shipping unlocked</span> for this order
        {% endif %}
      </p>
      <p class="free-shipping-detail">
        {% if amount_left > 0 %}
          Add one more favorite and we will cover delivery.
        {% else %}
          Your order is ready to ship on us.
        {% endif %}
      </p>

      <div
        class="free-shipping-track"
        role="progressbar"
        aria-label="Free shipping progress"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="{{ progress }}"
      >
        <div class="free-shipping-progress"></div>
        <span class="free-shipping-marker" aria-hidden="true">
          <span class="svg-wrapper">
            {{- 'icon-truck.svg' | inline_asset_content -}}
          </span>
        </span>
      </div>
    </div>
  </div>
{% endif %}
