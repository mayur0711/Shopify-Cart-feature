{% liquid
  assign total_savings = 0

  for item in cart.items
    if item.variant.compare_at_price > item.final_price
      assign item_saving = item.variant.compare_at_price | minus: item.final_price | times: item.quantity
      assign total_savings = total_savings | plus: item_saving
    endif
  endfor
%}

{% if settings.show_cart_saving and total_savings > 0 %}
  <div class="cart-savings-box" aria-live="polite">
    <p class="cart-savings-kicker">Your cart value</p>
    <div class="cart-savings-main">
      <span class="cart-savings-copy">You are saving</span>
      <strong class="cart-savings-amount">{{ total_savings | money }}</strong>
    </div>
    <p class="cart-savings-note">The best available prices are already reflected in your cart.</p>
  </div>
{% endif %}
